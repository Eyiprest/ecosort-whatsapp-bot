function msg(key, lang, ...args) {
  const l = lang === 'pid' ? 'pid' : 'en';
  const entry = t[key];
  if (!entry) return `[missing: ${key}]`;
  const val = entry[l];
  return typeof val === 'function' ? val(...args) : val;
}

module.exports = { msg, t };
